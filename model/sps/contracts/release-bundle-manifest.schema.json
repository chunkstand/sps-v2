{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/sps/contracts/ReleaseBundleManifest.schema.json",
  "title": "ReleaseBundleManifest",
  "version": "1.0.0",
  "description": "Release bundle manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "release_id",
    "spec_version",
    "app_version",
    "schema_version",
    "model_version",
    "policy_bundle_version",
    "adapter_versions",
    "invariant_pack_version",
    "artifact_digests",
    "approvals",
    "created_at"
  ],
  "properties": {
    "release_id": {
      "type": "string"
    },
    "spec_version": {
      "type": "string"
    },
    "app_version": {
      "type": "string"
    },
    "schema_version": {
      "type": "string"
    },
    "model_version": {
      "type": "string"
    },
    "policy_bundle_version": {
      "type": "string"
    },
    "adapter_versions": {
      "type": "object"
    },
    "invariant_pack_version": {
      "type": "string"
    },
    "artifact_digests": {
      "type": "object"
    },
    "approvals": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-artifact-metadata": {
    "artifact_id": "ART-SPS-CONTRACT-010",
    "authoritative_or_informative": "authoritative",
    "authored_or_generated": "generated_from_spec",
    "consumer_list": [
      "services",
      "CI",
      "reviewers"
    ],
    "owner": "Architecture Lead / Platform",
    "freshness_expectation": "must match current model export for release",
    "failure_if_missing": "merge_block"
  }
}