  "properties": {
    "contradiction_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "source_a": {
      "type": "string"
    },
    "source_b": {
      "type": "string"
    },
    "ranking_relation": {
      "type": "string"
    },
    "blocking_effect": {
      "type": "boolean"
