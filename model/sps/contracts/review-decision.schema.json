{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.internal/sps/contracts/ReviewDecision.schema.json",
  "title": "ReviewDecision",
  "version": "1.0.0",
  "description": "Authoritative reviewer outcome artifact.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "decision_id",
    "case_id",
    "object_type",
    "object_id",
    "decision_outcome",
    "reviewer_id",
    "reviewer_independence_status",
    "evidence_ids",
    "dissent_flag",
    "decision_at"
  ],
  "properties": {
    "decision_id": {
      "type": "string"
    },
    "case_id": {
      "type": "string"
    },
    "object_type": {
      "type": "string"
    },
    "object_id": {
      "type": "string"
    },
    "decision_outcome": {
      "type": "string",
      "enum": [
        "ACCEPT",
        "ACCEPT_WITH_DISSENT",
        "BLOCK"
      ]
    },
    "reviewer_id": {
      "type": "string"
    },
    "reviewer_independence_status": {
      "type": "string",
      "enum": [
        "PASS",
        "WARNING",
        "ESCALATION_REQUIRED",
        "BLOCKED",
        "OVERRIDE_APPLIED"
      ]
    },
    "evidence_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "contradiction_resolution": {
      "type": "string"
    },
    "dissent_flag": {
      "type": "boolean"
    },
    "notes": {
      "type": "string"
    },
    "decision_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "x-artifact-metadata": {
    "artifact_id": "ART-SPS-CONTRACT-002",
    "authoritative_or_informative": "authoritative",
    "authored_or_generated": "generated_from_spec",
    "consumer_list": [
      "services",
      "CI",
      "reviewers"
    ],
    "owner": "Architecture Lead / Platform",
    "freshness_expectation": "must match current model export for release",
    "failure_if_missing": "merge_block"
  }
}