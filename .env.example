# Copy to .env for local dev

# Postgres (app)
SPS_DB_HOST=localhost
SPS_DB_PORT=5432
SPS_DB_NAME=sps
SPS_DB_USER=sps
SPS_DB_PASSWORD=sps

# Temporal
SPS_TEMPORAL_ADDRESS=localhost:7233
SPS_TEMPORAL_NAMESPACE=default
SPS_TEMPORAL_TASK_QUEUE=sps-permit-case

# (Legacy alias accepted by Settings)
# TEMPORAL_ADDRESS=localhost:7233

TEMPORAL_UI_URL=http://localhost:8080

# Tests (opt-in integration)
# SPS_RUN_TEMPORAL_INTEGRATION=1

# Auth (local dev defaults)
SPS_AUTH_JWT_ISSUER=sps.local
SPS_AUTH_JWT_AUDIENCE=sps.api
SPS_AUTH_JWT_SECRET=dev-secret-0123456789abcdef0123456789

# S3-compatible evidence/artifact storage (MinIO via docker-compose)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
SPS_S3_ENDPOINT_URL=http://localhost:9000
SPS_S3_ACCESS_KEY=minio
SPS_S3_SECRET_KEY=minio123
SPS_S3_BUCKET_EVIDENCE=sps-evidence
SPS_S3_BUCKET_RELEASE=sps-release
