# Copy to .env for local dev

# Postgres (app)
SPS_DB_HOST=localhost
SPS_DB_PORT=5432
SPS_DB_NAME=sps
SPS_DB_USER=sps
SPS_DB_PASSWORD=sps

# Temporal
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_UI_URL=http://localhost:8080

# S3-compatible evidence/artifact storage (MinIO via docker-compose)
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=minio123
SPS_S3_ENDPOINT_URL=http://localhost:9000
SPS_S3_ACCESS_KEY=minio
SPS_S3_SECRET_KEY=minio123
SPS_S3_BUCKET_EVIDENCE=sps-evidence
SPS_S3_BUCKET_RELEASE=sps-release
